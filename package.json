{
  "name": "peek-viewer",
  "version": "0.1.0",
  "description": "轻量化本地文件查看器：CLI 启动，浏览器专属窗口渲染代码/Markdown/JSON/JSONL",
  "type": "module",
  "bin": {
    "peek": "bin/peek.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --config src/web/vite.config.ts",
    "dev:server": "tsx watch src/server/main.ts",
    "build:web": "vite build --config src/web/vite.config.ts",
    "build:node": "tsx scripts/build-node.ts",
    "build": "npm run build:web && npm run build:node",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/web/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "@tanstack/react-virtual": "^3.10.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.24.0",
    "markdown-it": "^14.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^1.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
